APPLE_CALDAV_USERNAME=your-apple-id@example.com
APPLE_CALDAV_PASSWORD=your-app-specific-password
# Optional. Leave empty to sync the first calendar Jarvis discovers.
# After adding credentials, call /calendar/apple/calendars to see exact names.
APPLE_CALDAV_CALENDAR_NAME=
APPLE_CALDAV_BASE_URL=https://caldav.icloud.com

# Later Alexa deployment settings
ALEXA_SKILL_ID=
PUBLIC_JARVIS_URL=

# Optional LLM reasoning layer. Leave empty to use local rule-based answers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
